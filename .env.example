# ============================================================
# AI Meeting Summarizer — Environment Configuration
# ============================================================
# Copy this file to .env and update the values.
# NEVER commit the .env file to version control.
# ============================================================

APP_NAME="AI Meeting Summarizer"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["*"]

DATABASE_URL=sqlite+aiosqlite:///./meeting_summarizer.db

# IMPORTANT: Generate a secure key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute

LOG_LEVEL=INFO
LOG_FORMAT=json
